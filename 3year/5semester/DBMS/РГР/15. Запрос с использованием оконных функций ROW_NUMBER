SELECT
    cl.full_name AS клиент,
    ch.charge_date,
    ch.amount,
    ROW_NUMBER() OVER (
        PARTITION BY co.client_id
        ORDER BY ch.charge_date
    ) AS номер_начисления
FROM Charge ch
JOIN Contract co ON ch.contract_id = co.contract_id
JOIN Client cl ON co.client_id = cl.client_id;
