SELECT
    cl.client_type                   AS тип_клиента,
    cl.full_name                     AS клиент,
    st.name                          AS услуга,
    COUNT(ch.charge_id)              AS кол_начислений,
    ROUND(AVG(ch.amount), 2)         AS средняя_сумма
FROM Charge      ch
JOIN Contract    co ON ch.contract_id      = co.contract_id
JOIN Client      cl ON co.client_id        = cl.client_id
JOIN ServiceType st ON co.service_type_id  = st.service_type_id
GROUP BY cl.client_type, cl.full_name, st.name
HAVING SUM(ch.amount - ch.paid_amount) > 0
ORDER BY cl.client_type ASC,
         cl.full_name   ASC,
         средняя_сумма  DESC;
