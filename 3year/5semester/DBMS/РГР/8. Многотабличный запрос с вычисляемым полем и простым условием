SELECT
    cl.full_name AS клиент,
    st.name AS услуга,
    ROUND(ch.amount - ch.paid_amount, 2) AS долг_руб
FROM Charge ch
JOIN Contract co ON ch.contract_id = co.contract_id
JOIN Client cl ON co.client_id = cl.client_id
JOIN ServiceType st ON co.service_type_id = st.service_type_id
WHERE ch.paid_amount < ch.amount;
