DROP TRIGGER IF EXISTS trg_check_reading ON MeterReading;

CREATE OR REPLACE FUNCTION trg_check_reading_fn()
RETURNS TRIGGER AS $$
DECLARE
    v_prev DECIMAL(12,4);
BEGIN
    SELECT COALESCE(
        MAX(reading_value),
        (SELECT initial_reading FROM Meter WHERE meter_id = NEW.meter_id)
    )
    INTO v_prev
    FROM MeterReading
    WHERE meter_id     = NEW.meter_id
      AND reading_date < NEW.reading_date;
 
    IF NEW.reading_value < v_prev THEN
        RAISE EXCEPTION
            'Ошибка: новое показание (%) не может быть меньше предыдущего (%).',
            NEW.reading_value, v_prev;
    END IF;
 
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;
 
CREATE TRIGGER trg_check_reading
BEFORE INSERT ON MeterReading
FOR EACH ROW
EXECUTE FUNCTION trg_check_reading_fn();