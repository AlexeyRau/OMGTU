31.1. Создание функции

CREATE OR REPLACE FUNCTION get_client_debt(p_client_id INT)
RETURNS DECIMAL(12,2)
AS $$
DECLARE
    v_debt DECIMAL(12,2);
BEGIN
    SELECT COALESCE(SUM(ch.amount - ch.paid_amount), 0)
      INTO v_debt
    FROM Contract co
    JOIN Charge   ch ON co.contract_id = ch.contract_id
    WHERE co.client_id = p_client_id;
 
    RETURN v_debt;
END;
$$ LANGUAGE plpgsql;

