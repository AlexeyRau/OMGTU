29. Курсор 1

DO $$
DECLARE
    cur_debt CURSOR FOR
        SELECT
            cl.full_name,
            cl.client_type,
            SUM(ch.amount - ch.paid_amount) AS долг
        FROM Client   cl
        JOIN Contract co ON cl.client_id   = co.client_id
        JOIN Charge   ch ON co.contract_id = ch.contract_id
        WHERE ch.paid_amount < ch.amount
        GROUP BY cl.client_id, cl.full_name, cl.client_type;
    rec RECORD;
BEGIN
    OPEN cur_debt;
    LOOP
        FETCH cur_debt INTO rec;
        EXIT WHEN NOT FOUND;
        RAISE NOTICE 'Должник: % (%) — долг: % руб.',
            rec.full_name, rec.client_type, ROUND(rec.долг, 2);
    END LOOP;
    CLOSE cur_debt;
END $$;

