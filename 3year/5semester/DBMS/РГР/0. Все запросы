32.1. Создание процедуры

CREATE OR REPLACE PROCEDURE distribute_payment(
    p_client_id  INT,
    p_amount     DECIMAL(12,2),
    p_date       DATE DEFAULT CURRENT_DATE
)
LANGUAGE plpgsql AS $$
DECLARE
    v_remaining DECIMAL(12,2) := p_amount;
    rec         RECORD;
BEGIN
    INSERT INTO Payment (client_id, amount, payment_date)
    VALUES (p_client_id, p_amount, p_date);
 
    FOR rec IN
        SELECT ch.charge_id,
               ch.amount - ch.paid_amount AS долг
        FROM Charge   ch
        JOIN Contract co ON ch.contract_id = co.contract_id
        WHERE co.client_id   = p_client_id
          AND ch.paid_amount < ch.amount
        ORDER BY ch.charge_date
    LOOP
        EXIT WHEN v_remaining <= 0;
 
        IF v_remaining >= rec.долг THEN
            UPDATE Charge
               SET paid_amount = amount
             WHERE charge_id = rec.charge_id;
            v_remaining := v_remaining - rec.долг;
        ELSE
            UPDATE Charge
               SET paid_amount = paid_amount + v_remaining
             WHERE charge_id = rec.charge_id;
            v_remaining := 0;
        END IF;
    END LOOP;
 
    RAISE NOTICE 'Платёж % руб. распределён. Остаток: % руб.',
        p_amount, v_remaining;
END;
$$;

