DROP TRIGGER IF EXISTS trg_check_reading ON MeterReading;

CREATE OR REPLACE FUNCTION trg_check_reading_fn()
RETURNS TRIGGER AS $$
DECLARE
    v_prev DECIMAL(12,4);
BEGIN
    SELECT COALESCE(
        MAX(reading_value),
        (SELECT initial_reading FROM Meter WHERE meter_id = NEW.meter_id)
    )
    INTO v_prev
    FROM MeterReading
    WHERE meter_id     = NEW.meter_id
      AND reading_date < NEW.reading_date;
 
    IF NEW.reading_value < v_prev THEN
        RAISE EXCEPTION
            'Ошибка: новое показание (%) не может быть меньше предыдущего (%).',
            NEW.reading_value, v_prev;
    END IF;
 
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;
 
CREATE TRIGGER trg_check_reading
BEFORE INSERT ON MeterReading
FOR EACH ROW
EXECUTE FUNCTION trg_check_reading_fn();

34. Триггер trg_create_charge

DROP TRIGGER IF EXISTS trg_create_charge ON MeterReading;

CREATE OR REPLACE FUNCTION trg_create_charge_fn()
RETURNS TRIGGER AS $$
DECLARE
    v_prev_val    DECIMAL(12,4);
    v_contract_id INT;
    v_service_id  INT;
    v_tariff_id   INT;
    v_price       DECIMAL(12,4);
    v_consumption DECIMAL(12,4);
BEGIN
    SELECT COALESCE(
        MAX(reading_value),
        (SELECT initial_reading FROM Meter WHERE meter_id = NEW.meter_id)
    )
    INTO v_prev_val
    FROM MeterReading
    WHERE meter_id     = NEW.meter_id
      AND reading_date < NEW.reading_date;
 
    SELECT m.contract_id, co.service_type_id
      INTO v_contract_id, v_service_id
    FROM Meter    m
    JOIN Contract co ON m.contract_id = co.contract_id
    WHERE m.meter_id = NEW.meter_id;
 
    SELECT tariff_id, price_per_unit
      INTO v_tariff_id, v_price
    FROM Tariff
    WHERE service_type_id = v_service_id
      AND valid_from      <= NEW.reading_date
      AND (valid_to IS NULL OR valid_to >= NEW.reading_date)
    ORDER BY valid_from DESC
    LIMIT 1;
 
    v_consumption := NEW.reading_value - v_prev_val;
 
    INSERT INTO Charge (contract_id, reading_id, tariff_id,
                        consumption, amount, charge_date)
    VALUES (v_contract_id, NEW.reading_id, v_tariff_id,
            v_consumption,
            ROUND(v_consumption * v_price, 2),
            NEW.reading_date);
 
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;
 
CREATE TRIGGER trg_create_charge
AFTER INSERT ON MeterReading
FOR EACH ROW
EXECUTE FUNCTION trg_create_charge_fn();

