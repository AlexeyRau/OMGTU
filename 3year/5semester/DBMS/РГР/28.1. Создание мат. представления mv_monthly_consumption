CREATE MATERIALIZED VIEW mv_monthly_consumption AS
SELECT
    m.meter_id,
    st.name                                           AS услуга,
    DATE_TRUNC('month', mr.reading_date)              AS период,
    COUNT(mr.reading_id)                              AS кол_показаний,
    MAX(mr.reading_value) - MIN(mr.reading_value)     AS потребление
FROM MeterReading mr
JOIN Meter       m  ON mr.meter_id         = m.meter_id
JOIN Contract    co ON m.contract_id       = co.contract_id
JOIN ServiceType st ON co.service_type_id  = st.service_type_id
GROUP BY m.meter_id, st.name, DATE_TRUNC('month', mr.reading_date);
