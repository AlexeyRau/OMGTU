SELECT
    mr.reading_id,
    cl.full_name AS клиент,
    st.name AS услуга,
    mr.reading_value AS показание,
    t.price_per_unit AS тариф,
    ROUND(mr.reading_value * t.price_per_unit, 2) AS расчётная_сумма
FROM MeterReading mr
JOIN Meter m  ON mr.meter_id = m.meter_id
JOIN Contract co ON m.contract_id = co.contract_id
JOIN Client cl ON co.client_id = cl.client_id
JOIN ServiceType st ON co.service_type_id = st.service_type_id
JOIN Tariff t  ON co.service_type_id = t.service_type_id
WHERE t.valid_to IS NULL;
