DROP MATERIALIZED VIEW IF EXISTS mv_client_debt;

CREATE MATERIALIZED VIEW mv_client_debt AS
SELECT
    cl.client_id,
    cl.full_name,
    cl.client_type,
    st.name                          AS услуга,
    SUM(ch.amount - ch.paid_amount)  AS общий_долг,
    COUNT(ch.charge_id)              AS кол_начислений
FROM Client      cl
JOIN Contract    co ON cl.client_id        = co.client_id
JOIN Charge      ch ON co.contract_id      = ch.contract_id
JOIN ServiceType st ON co.service_type_id  = st.service_type_id
WHERE ch.paid_amount < ch.amount
GROUP BY cl.client_id, cl.full_name, cl.client_type, st.name;
 
SELECT
    full_name            AS клиент,
    client_type          AS тип,
    услуга,
    ROUND(общий_долг, 2) AS долг_руб
FROM mv_client_debt
ORDER BY общий_долг DESC;
